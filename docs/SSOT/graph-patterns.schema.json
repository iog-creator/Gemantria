{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gemantria.org/schemas/graph-patterns.schema.json",
  "title": "Graph Patterns Schema",
  "description": "Schema for graph pattern analysis including motifs and structural patterns",
  "type": "object",
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Analysis timestamp"
    },
    "patterns": {
      "type": "array",
      "description": "Detected patterns",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Pattern type (triangle, square, etc.)"
          },
          "count": {
            "type": "integer",
            "description": "Number of occurrences",
            "minimum": 0
          },
          "nodes": {
            "type": "array",
            "description": "Node IDs in pattern",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["type", "count"]
      }
    }
  },
  "required": ["timestamp", "patterns"]
}