{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gemantria.org/schemas/pattern-forecast.schema.json",
  "title": "Pattern Forecast Schema",
  "description": "Schema for pattern forecasting including predictions and confidence intervals",
  "type": "object",
  "properties": {
    "model": {
      "type": "string",
      "description": "Forecasting model used"
    },
    "horizon": {
      "type": "integer",
      "description": "Forecast horizon in periods",
      "minimum": 1
    },
    "forecasts": {
      "type": "array",
      "description": "Forecast data points",
      "items": {
        "type": "object",
        "properties": {
          "period": {
            "type": "string",
            "description": "Forecast period"
          },
          "predicted_value": {
            "type": "number",
            "description": "Predicted value"
          },
          "lower_bound": {
            "type": "number",
            "description": "Confidence interval lower bound"
          },
          "upper_bound": {
            "type": "number",
            "description": "Confidence interval upper bound"
          },
          "confidence_level": {
            "type": "number",
            "description": "Confidence level (0-1)",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": ["period", "predicted_value"]
      }
    },
    "accuracy_metrics": {
      "type": "object",
      "description": "Model accuracy metrics",
      "properties": {
        "mae": {
          "type": "number",
          "description": "Mean Absolute Error"
        },
        "rmse": {
          "type": "number",
          "description": "Root Mean Square Error"
        },
        "mape": {
          "type": "number",
          "description": "Mean Absolute Percentage Error"
        }
      }
    }
  },
  "required": ["model", "horizon", "forecasts"]
}