{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gemantria.org/schemas/temporal-patterns.schema.json",
  "title": "Temporal Patterns Schema",
  "description": "Schema for temporal pattern analysis including time-series data",
  "type": "object",
  "properties": {
    "period": {
      "type": "string",
      "description": "Analysis period (daily, weekly, monthly)"
    },
    "data_points": {
      "type": "integer",
      "description": "Number of data points",
      "minimum": 0
    },
    "patterns": {
      "type": "array",
      "description": "Temporal patterns detected",
      "items": {
        "type": "object",
        "properties": {
          "pattern_type": {
            "type": "string",
            "description": "Type of temporal pattern"
          },
          "frequency": {
            "type": "number",
            "description": "Pattern frequency"
          },
          "confidence": {
            "type": "number",
            "description": "Pattern confidence score",
            "minimum": 0,
            "maximum": 1
          },
          "trend": {
            "type": "string",
            "enum": ["increasing", "decreasing", "stable", "cyclic"],
            "description": "Trend direction"
          }
        },
        "required": ["pattern_type", "frequency", "confidence"]
      }
    }
  },
  "required": ["period", "data_points"]
}